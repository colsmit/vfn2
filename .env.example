GHIDRA_INSTALL_DIR="/Applications/ghidra"

# Optional decompiler bootstrap controls.
GHIDRA_SKIP_AUTO_DOWNLOAD="0"
GHIDRA_AUTOINSTALL_PYGHIDRA="1"
# Optional shared home for the PyGhidra bridge; experiment runners set a run-local cache automatically.
BINARY_AGENT_GHIDRA_HOME=""

# Shared OpenRouter controls for opt-in model-assisted stages.
OPENROUTER_API_KEY=""
OPENROUTER_API_KEY_FILE=""
OPENROUTER_CHAT_COMPLETIONS_URL="https://openrouter.ai/api/v1/chat/completions"
OPENROUTER_MODEL="gpt-oss-120b"
OPENROUTER_HTTP_REFERER=""
OPENROUTER_APP_TITLE="vulnfinder2"

# Optional semantic target, hypothesis, and replay-repair provider controls.
BINARY_AGENT_SEMANTIC_SEED_MODEL="gpt-oss-120b"
BINARY_AGENT_SEMANTIC_SEED_BASE_URL=""
BINARY_AGENT_SEMANTIC_SEED_API_KEY_ENV=""
BINARY_AGENT_HYPOTHESIS_MODEL="gpt-oss-120b"
BINARY_AGENT_HYPOTHESIS_BASE_URL=""
BINARY_AGENT_HYPOTHESIS_API_KEY_ENV=""
BINARY_AGENT_REPLAY_REPAIR_MODEL="gpt-oss-120b"
BINARY_AGENT_REPLAY_REPAIR_BASE_URL=""
BINARY_AGENT_REPLAY_REPAIR_API_KEY_ENV=""

# Autonomous adjudication. The direct tier receives one bounded immutable JSON
# pack. The optional agent command receives the same pack on stdin and should
# return the investigation-proposal schema on stdout. Example runtime value:
# BINARY_AGENT_ADJUDICATION_AGENT_COMMAND="pi --mode exec ..."
BINARY_AGENT_ADJUDICATION_MODEL="gpt-oss-120b"
BINARY_AGENT_ADJUDICATION_BASE_URL=""
BINARY_AGENT_ADJUDICATION_API_KEY_ENV=""
BINARY_AGENT_ADJUDICATION_TIMEOUT_SECONDS="120"
BINARY_AGENT_ADJUDICATION_MAX_TOKENS="6000"
BINARY_AGENT_ADJUDICATION_AGENT_COMMAND=""

# Optional replay controls for the proof-gated pipeline.
QEMU_USER_BIN=""
QEMU_SYSTEM_BIN=""
REPLAY_TIMEOUT_SECONDS="10"
REHOST_COMMAND_TEMPLATE=""
CONTAINER_SERVICE_COMMAND_TEMPLATE=""
